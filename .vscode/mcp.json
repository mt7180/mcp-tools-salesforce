{
	"servers": {
		"custom-salesforce-tools": {
			"type": "stdio",
			"command": "uv",
			"args": [
				"run",
				"--with",
				"fastmcp",
				"fastmcp",
				"run",
				"server.py"
			]
		},
		"Salesforce DX": {
			"command": "npx",
			"args": ["-y", "@salesforce/mcp@latest", 
					"--orgs", "DEFAULT_TARGET_ORG", 
					"--toolsets", "orgs,metadata,data,users,testing"]
		}
	},
		"inputs": []
}